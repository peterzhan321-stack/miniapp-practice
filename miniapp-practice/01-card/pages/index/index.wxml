<!--index.wxml-->
<!-- 个人名片页面 -->
<view class="container">
  
  <!-- 顶部：头像、姓名、专业年级 -->
  <view class="header-section">
    <!-- 头像占位（圆形） -->
    <view class="avatar"></view>
    <!-- 姓名 -->
    <text class="name">{{name}}</text>
    <!-- 专业年级 -->
    <text class="major">{{major}}</text>
  </view>
  
  <!-- 中部：联系方式列表 -->
  <view class="contacts-section">
    <text class="section-title">联系方式</text>
    <view class="contacts-list">
      <!-- 使用 wx:for 渲染 contacts 数组 -->
      <view wx:for="{{contacts}}" wx:key="index" class="contact-item">
        <text class="contact-label">{{item.label}}：</text>
        <text class="contact-value">{{item.value}}</text>
      </view>
    </view>
  </view>
  
  <!-- 下部：技能标签 -->
  <view class="skills-section">
    <text class="section-title">技能标签</text>
    <view class="skills-list">
      <!-- 使用 wx:for 渲染 skills 数组 -->
      <view wx:for="{{skills}}" wx:key="index" class="skill-tag" bindtap="onSkillTap" data-skill="{{item}}">
        <text class="skill-text">{{item}}</text>
      </view>
    </view>
  </view>
  
  <!-- 底部：个人简介文本 -->
  <view class="bio-section">
    <text class="section-title">个人简介</text>
    <text class="bio-text">{{bio}}</text>
  </view>
  
</view>
