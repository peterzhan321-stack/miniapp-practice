/* poster-card 组件样式 */

/* 海报卡片 */
.poster-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.poster-card:active {
  transform: scale(0.98);
}

/* 图片容器 */
.image-wrapper {
  position: relative;
  width: 100%;
  min-height: 200rpx;
  background-color: #f5f5f5;
}

/* 海报图片 */
.poster-image {
  width: 100%;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.poster-image.loaded {
  opacity: 1;
}

/* 图片加载占位 */
.image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 16rpx 16rpx 0 0;
}

/* 加载动画 */
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 海报信息区域 */
.poster-info {
  padding: 20rpx;
}

/* 海报标题 */
.poster-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 海报元信息 */
.poster-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.date-tag {
  font-size: 24rpx;
  color: #ff6b6b;
  background-color: rgba(255, 107, 107, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
}

.location {
  font-size: 24rpx;
  color: #666666;
}

/* 社团信息 */
.club-info {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.club-name {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

/* 点赞区域 */
.like-section {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 10rpx;
}

.like-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.like-btn:active {
  transform: scale(0.9);
}

.like-icon {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.like-btn.liked .like-icon {
  color: #ff6b6b;
}

.like-count {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
  min-width: 40rpx;
}
